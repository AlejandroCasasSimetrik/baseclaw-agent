# ─── Environment ────────────────────────────────────────
NODE_ENV=development

# ─── LLM Provider ───────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key

# ─── LangSmith Observability ────────────────────────────
LANGCHAIN_API_KEY=ls__your-langsmith-api-key
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=BaseClaw
LANGCHAIN_CALLBACKS_BACKGROUND=true

# ─── LangSmith Level 4 (Observability & Evaluation) ────
LANGSMITH_ORG_ID=your-org-id
LANGSMITH_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
LANGSMITH_COST_THRESHOLD=10

# ─── PostgreSQL (Episodic Memory) ──────────────────────
DATABASE_URL=postgresql://user:password@host:5432/baseclaw

# ─── Pinecone (Semantic Memory) ────────────────────────
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=baseclaw

# ─── Level 5 — Dynamic RAG Pipeline ───────────────────────
LLAMAPARSE_API_KEY=your-llamaparse-api-key
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_MAX_FILE_SIZE=52428800
RAG_EMBEDDING_BATCH_SIZE=100

# ─── Level 7 — Voice I/O ──────────────────────────────────
STT_PROVIDER=whisper
DEEPGRAM_API_KEY=your-deepgram-api-key
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=your-voice-id
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
TTS_ENABLED=true
VOICE_MAX_AUDIO_DURATION_SECONDS=300
VOICE_MAX_AUDIO_SIZE_BYTES=26214400

# ─── Level 9 — Heartbeat & HITL ──────────────────────────────
HEARTBEAT_INTERVAL_MS=1800000
HEARTBEAT_ENABLED=true
HEARTBEAT_MAX_TASK_DURATION_MS=3600000

# ─── Level 10 — Reviewer Loop ────────────────────────────────
REVIEW_AUTO_APPROVE_THRESHOLD=85
REVIEW_HITL_THRESHOLD=40
MAX_REVISION_ROUNDS=3
REVIEW_CHECKPOINT_INTERVAL=3

# ─── Dev Console ──────────────────────────────────────────
ENABLE_DEV_CONSOLE=true
DEV_CONSOLE_TOKEN=
