{
  "name": "baseclaw-agent",
  "version": "0.1.0",
  "description": "Base Claw — Reusable multi-agent architecture built on LangGraph.js",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./src/*": "./src/*"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
